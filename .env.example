APP_NAME=markweb
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://markweb.goldcoast.org

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=192.168.2.210
DB_PORT=5432
DB_DATABASE=markweb
DB_USERNAME=markweb
DB_PASSWORD=markweb

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Reverb
REVERB_APP_ID=markweb
REVERB_APP_KEY=markweb-key
REVERB_APP_SECRET=markweb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# JMAP (Stalwart)
JMAP_URL=https://mail.goldcoast.org
JMAP_HOSTNAME=mail.goldcoast.org

# Ollama (embeddings)
OLLAMA_URL=http://192.168.2.130:11434
OLLAMA_MODEL=nomic-embed-text

# Agent
AGENT_DEFAULT_MODEL=claude-sonnet-4-20250514
AGENT_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
