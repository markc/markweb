#!/usr/bin/env bash
# Deploy markweb to mesh nodes
# Usage: bin/deploy [node|all] [--skip-build]
#   bin/deploy              # deploy to mko (default)
#   bin/deploy mmc          # deploy to mmc
#   bin/deploy all          # deploy to all remote nodes
#   bin/deploy --skip-build # mko, skip frontend build
#   bin/deploy mmc --skip-build

set -euo pipefail

# Node config: SSH host, app path, vhost user
declare -A NODE_APP NODE_USER
NODE_APP[mko]="/srv/web.kanary.org/web/app"
NODE_USER[mko]="u1001"
NODE_APP[mmc]="/srv/web.motd.com/web/app"
NODE_USER[mmc]="u1002"

ALL_NODES=(mko mmc)

# Parse arguments
TARGET=""
SKIP_BUILD=false
for arg in "$@"; do
    case "$arg" in
        --skip-build) SKIP_BUILD=true ;;
        *) TARGET="$arg" ;;
    esac
done
TARGET="${TARGET:-mko}"

# Check we're on main with a clean tree
branch=$(git branch --show-current)
if [[ "$branch" != "main" ]]; then
    echo "ERROR: on branch '$branch', switch to main first" >&2
    exit 1
fi

if [[ -n "$(git status --porcelain)" ]]; then
    echo "ERROR: uncommitted changes, commit first" >&2
    exit 1
fi

# Push to GitHub
echo "==> Pushing to GitHub..."
git push

# Deploy to a single node
deploy_node() {
    local node="$1"
    local app="${NODE_APP[$node]}"
    local user="${NODE_USER[$node]}"

    echo "==> [$node] Pulling as $user..."
    ssh "$node" "sudo -u $user git -C $app pull"

    if [[ "$SKIP_BUILD" == false ]]; then
        echo "==> [$node] Building frontend..."
        ssh "$node" "sudo -u $user bash -c 'export PATH=\"\$HOME/.bun/bin:\$PATH\" && cd $app && bun run build'"
    else
        echo "==> [$node] Skipping frontend build"
    fi

    echo "==> [$node] Clearing caches..."
    ssh "$node" "cd $app && php artisan route:cache && php artisan config:cache"

    echo "==> [$node] Done"
}

# Deploy
if [[ "$TARGET" == "all" ]]; then
    for node in "${ALL_NODES[@]}"; do
        deploy_node "$node"
    done
else
    if [[ -z "${NODE_APP[$TARGET]+x}" ]]; then
        echo "ERROR: unknown node '$TARGET' (known: ${ALL_NODES[*]})" >&2
        exit 1
    fi
    deploy_node "$TARGET"
fi

echo "==> Deploy complete"
